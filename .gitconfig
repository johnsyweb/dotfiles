# vi: noet ts=8 sw=8

[user]
	email = paj+github@johnsy.com
	name = Pete Johns
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMEe7zVz32CKDjmhNyEnUbZvdK0knnqCOqC6DIUlC5Cu
[alias]
	br = branch
	bump = "commit -m 'Bump' --allow-empty"
	ci = commit
	co = checkout
	cp = cherry-pick
	cr = log --abbrev-commit -p
	df = diff
	lg = log --graph --pretty=format:'%C(yellow)%h%Creset -%C(red)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --all --decorate
	mt = mergetool
	st = status
	stp = status --porcelain
	to-deploy = log --merges --grep='pull request' --format='%s (%cN)' origin/production..origin/master
	today = diff --stat '@{yesterday}'
	wc = whatchanged --abbrev-commit
	praise = blame
[core]
	autocrlf = input
	excludesFile = /Users/paj/src/dotfiles/git-global-ignore
	pager = less -+$LESS -FRX
	whitespace=fix,-indent-with-non-tab,trailing-space,cr-at-eol
[web]
	browser = google-chrome
[browser "google-chrome"]
	cmd = /usr/bin/google-chrome
[merge]
	tool=vimdiff
[push]
	default = current
[github]
	user = johnsyweb
[credential]
	helper = osxkeychain
[commit]
	gpgsign = true
[buildkite]
	apikey = REDACTED
[pull]
	ff = only
[init]
	defaultBranch = main
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
